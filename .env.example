API_PORT=3000
API_BASE_URL=http://127.0.0.1:3000
# Postgres connection for multi-instance deployments. When set, apply the
# schema once with `pnpm --filter @xiaochengxu/api db:migrate:pg`. Route
# code currently still reads/writes sqlite; switching routes to pg is
# tracked in project-status.md (partial).
# DATABASE_URL=postgres://xiaochengxu:dev-local@127.0.0.1:5432/xiaochengxu
# Shared secret between API and jobs worker for /api/internal/* endpoints.
# Leave empty in dev to disable auth; MUST be set in production.
INTERNAL_API_TOKEN=dev-internal-secret
REDIS_URL=redis://127.0.0.1:6379
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=alerts@xiaochengxu.local
SMS_PROVIDER=mock
MONITOR_TICK_INTERVAL_MS=300000
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute
# When set, @fastify/rate-limit uses Redis instead of in-memory store so multiple
# API instances share the same counter.
# RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/1

# Tool executor TTL cache (ms). Results are keyed by (tool, input kind, normalized value).
TOOL_CACHE_TTL_MS=300000

# CourtListener live API token — when set, tro_alert and case_progress use the
# real CourtListener REST v4 API. Leave empty to keep using fixture data.
# Get a free token at https://www.courtlistener.com/help/api/rest/
COURTLISTENER_API_TOKEN=
# COURTLISTENER_BASE_URL=https://www.courtlistener.com

# USPTO trademark search — point at your own proxy service that accepts {term}
# or {termEncoded} and returns JSON with marks[]
# USPTO_SEARCH_URL_TEMPLATE=https://your-uspto-proxy.example/marks?q={termEncoded}
# USPTO_AUTH_HEADER=Bearer your-token

# Amazon listing — point at your own proxy (Keepa / Rainforest / custom scraper).
# Listing endpoint returns raw HTML or JSON {html: string}.
# Store endpoint returns JSON {items: [{asin, title}]}.
# AMAZON_LISTING_URL_TEMPLATE=https://your-amazon-proxy.example/listing?asin={asin}
# AMAZON_STORE_URL_TEMPLATE=https://your-amazon-proxy.example/store?name={storeEncoded}
# AMAZON_AUTH_HEADER=Bearer your-token

# Optional: Sentry error monitoring. When set AND `@sentry/node` is installed,
# the API forwards uncaught errors via captureException. Always also logs to
# stderr as JSON lines.
# SENTRY_DSN=https://public-key@sentry.example/1

# WeChat mini-program auth. When both appid and secret are set, POST /api/auth/wechat
# exchanges a wx.login code for openid via jscode2session. Leave blank to keep
# only anonymous auth (H5 default).
# WECHAT_APPID=
# WECHAT_SECRET=
# WECHAT_JSCODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session

# Taro build-time env vars (read when running pnpm --filter @xiaochengxu/miniprogram build)
TARO_APP_API_BASE=http://127.0.0.1:3000
